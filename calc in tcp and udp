#include "ns3/core-module.h"
#include "ns3/network-module.h"
#include "ns3/internet-module.h"
#include "ns3/point-to-point-module.h"
#include "ns3/applications-module.h"
#include <vector>

using namespace ns3;

NS_LOG_COMPONENT_DEFINE ("MultiClientChat");

// ---------------- SERVER APPLICATION ----------------

class ChatServer : public Application
{
public:
    ChatServer () : m_socket(0), m_port(9000) {}

    void Setup(uint16_t port)
    {
        m_port = port;
    }

private:

    virtual void StartApplication ()
    {
        Ptr<SocketFactory> factory =
            GetNode()->GetObject<SocketFactory>(UdpSocketFactory::GetTypeId());

        m_socket = factory->CreateSocket();

        m_socket->Bind(InetSocketAddress(Ipv4Address::GetAny(), m_port));

        m_socket->SetRecvCallback(
            MakeCallback(&ChatServer::ReceivePacket, this));
    }

    void ReceivePacket(Ptr<Socket> socket)
    {
        Ptr<Packet> packet;
        Address sender;

        while((packet = socket->RecvFrom(sender)))
        {
            uint32_t packetSize = packet->GetSize();

            double timeStamp = Simulator::Now().GetSeconds();

            std::stringstream reply;

            reply << "ACK | Received at: "
                  << timeStamp
                  << "s | Size: "
                  << packetSize
                  << " bytes";

            std::string response = reply.str();

            NS_LOG_UNCOND("Server processing message from "
                          << InetSocketAddress::ConvertFrom(sender).GetIpv4());

            Ptr<Packet> ackPacket =
                Create<Packet>((uint8_t*)response.c_str(),
                               response.length());

            socket->SendTo(ackPacket,0,sender);
        }
    }

    Ptr<Socket> m_socket;
    uint16_t m_port;
};

// ---------------- CLIENT APPLICATION ----------------

class ChatClient : public Application
{
public:
    ChatClient() : m_socket(0) {}

    void Setup(Address serverAddress,
               Time sendInterval,
               std::string clientID)
    {
        m_peer = serverAddress;
        m_interval = sendInterval;
        m_name = clientID;
    }

private:

    virtual void StartApplication()
    {
        m_socket = Socket::CreateSocket(
            GetNode(), UdpSocketFactory::GetTypeId());

        m_socket->Connect(m_peer);

        m_socket->SetRecvCallback(
            MakeCallback(&ChatClient::ReceiveResponse,this));

        SendMessage();
    }

    void SendMessage()
    {
        std::string text = "Hello from " + m_name;

        Ptr<Packet> packet =
            Create<Packet>((uint8_t*)text.c_str(), text.length());

        m_socket->Send(packet);

        Simulator::Schedule(m_interval,
                            &ChatClient::SendMessage,
                            this);
    }

    void ReceiveResponse(Ptr<Socket> socket)
    {
        Ptr<Packet> packet = socket->Recv();

        std::vector<uint8_t> buffer(packet->GetSize());

        packet->CopyData(buffer.data(), packet->GetSize());

        std::string data((char*)buffer.data(), packet->GetSize());

        NS_LOG_UNCOND("[" << m_name
                          << "] Response From Server -> "
                          << data);
    }

    Ptr<Socket> m_socket;
    Address m_peer;
    Time m_interval;
    std::string m_name;
};

// ---------------- NETWORK TOPOLOGY ----------------

int main()
{

NodeContainer nodes;
nodes.Create(3);

PointToPointHelper p2p;

p2p.SetDeviceAttribute("DataRate", StringValue("5Mbps"));
p2p.SetChannelAttribute("Delay", StringValue("2ms"));

NetDeviceContainer linkA =
    p2p.Install(nodes.Get(1), nodes.Get(0));

NetDeviceContainer linkB =
    p2p.Install(nodes.Get(2), nodes.Get(0));

InternetStackHelper stack;
stack.Install(nodes);

Ipv4AddressHelper address;

address.SetBase("10.1.1.0","255.255.255.0");
Ipv4InterfaceContainer ifaceA = address.Assign(linkA);

address.SetBase("10.2.1.0","255.255.255.0");
Ipv4InterfaceContainer ifaceB = address.Assign(linkB);

// SERVER

Ptr<ChatServer> server = CreateObject<ChatServer>();
server->Setup(9000);

nodes.Get(0)->AddApplication(server);

// CLIENT A

Ptr<ChatClient> clientA = CreateObject<ChatClient>();

clientA->Setup(
    InetSocketAddress(ifaceA.GetAddress(1),9000),
    Seconds(3.0),
    "CLIENT_A"
);

nodes.Get(1)->AddApplication(clientA);

// CLIENT B

Ptr<ChatClient> clientB = CreateObject<ChatClient>();

clientB->Setup(
    InetSocketAddress(ifaceB.GetAddress(1),9000),
    Seconds(5.0),
    "CLIENT_B"
);

nodes.Get(2)->AddApplication(clientB);

NS_LOG_UNCOND("--- Simulation Started ---");

Simulator::Stop(Seconds(15.0));

Simulator::Run();
Simulator::Destroy();

NS_LOG_UNCOND("--- Simulation Completed ---");

return 0;

}
